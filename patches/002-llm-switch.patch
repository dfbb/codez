+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn force_context_window_bypasses_fallback_clamp() {
+    // codez llm-switch:未知 slug 走 fallback(max_context_window=272_000)；
+    // 普通 model_context_window 会被 clamp 到 272k，force_context_window 不会。
+    let codex_home = TempDir::new().expect("create temp dir");
+    let config = ModelsManagerConfig {
+        force_context_window: Some(1_000_000),
+        ..Default::default()
+    };
+    let manager = openai_manager_for_tests(
+        codex_home.path().to_path_buf(),
+        TestModelsEndpoint::new(Vec::new()),
+    );
+
+    let model_info = manager.get_model_info("deepseek-v4-pro", &config).await;
+
+    assert_eq!(model_info.context_window, Some(1_000_000));
+    assert_eq!(model_info.max_context_window, Some(1_000_000));
+    assert_eq!(model_info.resolved_context_window(), Some(1_000_000));
+}
