+}
+
+/// codez llm-switch:被本地接管的 provider（如 deepseek 走 Chat Completions）在 v1
+/// 仅支持标准 `function` 工具，命名空间 / web_search / image_generation 等托管工具
+/// 无法在目标协议中表达，会触发连接器硬失败（§4.0b）。当该 provider 配置了
+/// `captype = "chat"`（缺省）时按「无任何托管能力」处理，复用 codex 原生的能力门控
+/// 从源头不产生这些工具；`captype = "response"`（出口仍走 Responses）则透传原能力。
+/// 连接器里的硬失败保留作兜底安全网。
+fn provider_capabilities(
+    turn_context: &TurnContext,
+) -> codex_model_provider::ProviderCapabilities {
+    if codez_llm_switch::suppress_hosted_tools(&turn_context.config.model_provider_id) {
+        return codex_model_provider::ProviderCapabilities {
+            namespace_tools: false,
+            image_generation: false,
+            // anthropic 连接器能把 web_search 翻译成 Anthropic 原生 server tool，
+            // 故对走 anthropic 连接器的 provider 放开（其余仍随 suppress 关闭）。
+            web_search: codez_llm_switch::allow_anthropic_web_search(
+                &turn_context.config.model_provider_id,
+            ),
+        };
+    }
+    turn_context.provider.capabilities()
 }
 
